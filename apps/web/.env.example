# Public — exposed to client
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbG...

# Server-only — NEVER expose
SUPABASE_SERVICE_ROLE_KEY=eyJhbG...

# LLM — OpenAI-compatible gateway (OpenRouter / 9router / self-hosted)
# Set base URL of your gateway; key goes in OPENROUTER_API_KEY.
LLM_GATEWAY_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
# Alternatives
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Stock + TTS
PEXELS_API_KEY=...
EDGE_TTS_ENABLED=1

# Billing
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_BUSINESS=price_...

# Render engine signing key (private)
RENDER_JWT_PRIVATE_KEY=-----BEGIN EC PRIVATE KEY-----...
RENDER_JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----...
